# Production backend env template
NODE_ENV=production
PORT=3001

# Use internal service names in docker network, or external hostnames in client infra
DATABASE_URL=postgresql://irrigation_user:replace-with-strong-password@postgres:5432/irrigation

INFLUX_HOST=influxdb
INFLUX_PORT=8086
INFLUX_DATABASE=telegraf
INFLUX_USERNAME=root
INFLUX_PASSWORD=root

MQTT_BROKER_URL=mqtt://mosquitto:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# REQUIRED: long random secret in production
JWT_SECRET=replace-with-64-char-random-secret

# Restrict to dashboard origin(s)
CORS_ORIGIN=http://192.168.2.10:3000
